{
  "name": "@cellcog/openclaw-plugin",
  "version": "2.0.0",
  "description": "CellCog — any-to-any AI sub-agent plugin for OpenClaw. Generate images, videos, PDFs, presentations, research reports, music, spreadsheets, 3D models, memes, and more.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "CellCog",
    "email": "support@cellcog.ai",
    "url": "https://cellcog.ai"
  },
  "homepage": "https://cellcog.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/CellCog/cellcog-plugin"
  },
  "keywords": [
    "openclaw", "openclaw-plugin", "cellcog", "ai-agent", "sub-agent",
    "image-generation", "video-generation", "pdf", "research", "music",
    "spreadsheet", "3d-model", "multi-modal", "any-to-any", "deep-research"
  ],
  "files": [
    "skills/",
    "rules/",
    "commands/",
    "assets/",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      {
        "id": "cellcog-skills",
        "kind": "tool",
        "skills": [
          "skills/cellcog",
          "skills/video-cog",
          "skills/image-cog",
          "skills/audio-cog",
          "skills/music-cog",
          "skills/research-cog",
          "skills/docs-cog",
          "skills/slides-cog",
          "skills/spreadsheets-cog",
          "skills/proto-cog",
          "skills/3d-cog",
          "skills/meme-cog",
          "skills/diagram-cog",
          "skills/data-cog",
          "skills/game-cog",
          "skills/sticker-cog"
        ]
      }
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  }
}
